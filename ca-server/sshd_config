Port 2222
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AllowAgentForwarding yes

# Use PAM to hook into auth
UsePAM yes

# Default users (alice, bob, charlie)
ForceCommand /usr/local/bin/issue-user-cert.sh

# The provision user handles issuing host certificates via command params
Match User provision
    AllowAgentForwarding no
    ForceCommand /usr/local/bin/provision-handler.sh
