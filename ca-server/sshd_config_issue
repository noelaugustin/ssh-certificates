Port 22
PermitRootLogin yes
PasswordAuthentication yes
PubkeyAuthentication no

# Host Certificate for native trust
HostKey /etc/ssh/ca_host_key
HostCertificate /etc/ssh/ca_host_key-cert.pub
HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-ed25519

# Default users (npc, mc, god)
AllowAgentForwarding yes
ForceCommand /usr/local/bin/issue-user-cert.sh

# The provision user handles issuing host certificates
Match User provision
    ForceCommand /usr/local/bin/provision-handler.sh
